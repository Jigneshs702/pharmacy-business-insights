---
import Base from '../layouts/Base.astro';
import NewsletterBox from '../components/NewsletterBox.astro';
import { getCollection } from 'astro:content';
import { SITE, AUTHOR } from '../config/site';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = articles.slice(0, 6);
---

<Base
  title={`${SITE.name} — ${SITE.tagline}`}
  description="Practical, numbers-led guides that help UK pharmacy owners add private services, win more patients and automate their pharmacy. Written by a pharmacy growth specialist."
  noNewsletter
>
  <section class="section" style="text-align:center; padding-top:4.5rem;">
    <div class="container" style="max-width:900px;">
      <span class="pill">For UK pharmacy owners &amp; managers</span>
      <h1 style="max-width:850px; margin-left:auto; margin-right:auto;">
        Your pharmacy should be making <span style="color:var(--blue);">more money.</span><br />Let's fix that.
      </h1>
      <p style="font-size:1.35rem; color:var(--muted); max-width:680px; margin:0 auto 2rem;">
        Practical, numbers-led playbooks on private services, marketing and AI — written from
        real work with UK pharmacies, not recycled press releases.
      </p>
      <div style="display:flex; flex-direction:column; gap:1.4rem; align-items:center;">
        <div>
          <a href="/tools/profit-calculator/" class="btn" style="font-size:1.15rem; padding:1.05rem 2.3rem;">See what your pharmacy could earn</a>
          <p class="muted small" style="margin:0.8rem auto 0; max-width:340px;">Free calculator — pick your services, see the annual number in 30 seconds.</p>
        </div>
        <div>
          <a href="/private-services/" class="btn btn-outline">Read the private services playbook</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-blue">
    <div class="container">
      <div style="background:#fff; border:1px solid var(--blue-100); border-radius:24px; box-shadow:0 20px 45px -20px rgba(2,6,23,0.18); padding:2.5rem 2rem; display:grid; gap:2rem; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); text-align:center;">
        <div>
          <div class="stat-num">£50–150k</div>
          <div class="stat-label">what well-run private services add per year</div>
        </div>
        <div>
          <div class="stat-num">£60</div>
          <div class="stat-label">for a 25-minute ear wax appointment</div>
        </div>
        <div>
          <div class="stat-num">£900+</div>
          <div class="stat-label">a single family travel clinic booking</div>
        </div>
        <div>
          <div class="stat-num">24/7</div>
          <div class="stat-label">an AI agent answering while you dispense</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="text-align:center; max-width:640px; margin:0 auto 2.5rem;">
        <h2 style="margin-top:0;">What do you want to do?</h2>
        <p class="muted">Pick your goal — every path comes with real numbers and a step-by-step playbook.</p>
      </div>
      <div class="grid">
        <a class="card" href="/private-services/">
          <span class="eyebrow">Revenue engine</span>
          <h3>Add a profitable private service</h3>
          <p>Travel clinics, ear wax removal, weight management — what they really make and how to launch them.</p>
        </a>
        <a class="card" href="/services/bookings-booster/">
          <span class="eyebrow">More patients</span>
          <h3>Fill your clinic with bookings</h3>
          <p>Get found on Google and turn searches into booked, paying appointments.</p>
        </a>
        <a class="card" href="/services/ai-agents/">
          <span class="eyebrow">Automation</span>
          <h3>Put AI to work in your pharmacy</h3>
          <p>AI agents that answer calls, chase follow-ups and take bookings while you dispense.</p>
        </a>
        <a class="card" href="/tools/profit-calculator/">
          <span class="eyebrow">Free tool</span>
          <h3>See your profit potential</h3>
          <p>Pick your services, enter your numbers, and see what private income you're leaving on the table.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <h2 style="margin-top:0; text-align:center;">Latest playbooks</h2>
      <div class="grid" style="margin-top:2rem;">
        {featured.map((a) => (
          <a class="card" href={`/${a.data.category}/${a.id}/`}>
            <span class="eyebrow">{a.data.categoryTitle}</span>
            <h3>{a.data.title}</h3>
            <p>{a.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-navy" style="text-align:center;">
    <div class="container" style="max-width:820px;">
      <h2 style="margin-top:0;">Rather have it done for you?</h2>
      <p style="font-size:1.2rem;">
        Everything on this site is what I do all day for UK pharmacies: Google visibility,
        booking systems, websites and AI agents that fill private clinics.
      </p>
      <a href="/services/" class="btn" style="margin-top:0.5rem;">See how I can help your pharmacy</a>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px;">
      <h2 style="margin-top:0;">Who writes this?</h2>
      <p>
        I'm <a href="/about/">{AUTHOR.name}</a>, {AUTHOR.credential}. {AUTHOR.bio}
      </p>
      <NewsletterBox />
    </div>
  </section>
</Base>
