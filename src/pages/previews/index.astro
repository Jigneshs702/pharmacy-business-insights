---
const options = [
  { slug: 'broadsheet', name: '1 — The Broadsheet', desc: 'Ivory editorial paper, serif masthead, oxblood accents' },
  { slug: 'hub', name: '2 — The Hub', desc: 'Search-first resource library with topic tiles' },
  { slug: 'journal', name: '3 — The Private Journal', desc: 'Dark charcoal + gold, members-club exclusivity' },
  { slug: 'terminal', name: '4 — The Terminal', desc: 'Data ticker + dense briefing grid' },
  { slug: 'quiet', name: '5 — The Quiet Luxury', desc: 'Airy sage/cream, lowercase display type' },
  { slug: 'cover', name: '6 — The Cover Story', desc: 'Bold magazine cover, giant type, rotating issues' },
];
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Homepage design previews — PBI</title>
</head>
<body style="font-family:-apple-system,Segoe UI,sans-serif; max-width:640px; margin:3rem auto; padding:0 1.25rem; line-height:1.6;">
  <h1 style="letter-spacing:-0.02em;">Six homepage concepts</h1>
  <p style="color:#555;">Click each to see it full-size with the real content. These pages are hidden from Google.</p>
  <ol style="display:grid; gap:0.9rem; padding-left:1.2rem;">
    {options.map((o) => (
      <li>
        <a href={`/previews/${o.slug}/`} style="font-weight:700; font-size:1.1rem;">{o.name}</a>
        <div style="color:#777; font-size:0.95rem;">{o.desc}</div>
      </li>
    ))}
  </ol>
</body>
</html>
