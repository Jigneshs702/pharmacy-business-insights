---
import { getCollection } from 'astro:content';
const articles = (await getCollection('articles')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const lead = articles[0];
const toc = articles.slice(1, 6);
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>The Cover Story — homepage concept 6 | PBI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <style>
    :root { --navy:#0f172a; --deep:#020617; --yellow:#ffd100; --dim:#94a3b8; --line:#1e293b; --paper:#fff; }
    * { box-sizing:border-box; }
    body { margin:0; font-family:Inter,-apple-system,sans-serif; background:var(--paper); color:var(--navy); line-height:1.6; }
    .wrap { max-width:1040px; margin:0 auto; padding:0 1.5rem; }
    a { text-decoration:none; color:inherit; }
    .toc-item:hover .tt { color:#0284c7; }
    .btn { display:inline-block; background:var(--yellow); color:var(--navy); font-weight:700; padding:0.85rem 1.8rem; border-radius:6px; font-size:0.95rem; }
    .btn:hover { background:#facc15; }
    nav.cn a { font-size:0.82rem; letter-spacing:0.12em; color:var(--dim); }
    nav.cn a:hover { color:var(--yellow); }
  </style>
</head>
<body>
  <section style="background:var(--navy); color:#fff;">
    <div class="wrap" style="display:flex; justify-content:space-between; align-items:center; padding-top:1.3rem; flex-wrap:wrap; gap:0.75rem;">
      <span style="font-weight:900; letter-spacing:0.18em; font-size:0.95rem;">PBI MAGAZINE</span>
      <nav class="cn" style="display:flex; gap:1.5rem;">
        <a href="/private-services/">PLAYBOOKS</a>
        <a href="/tools/profit-calculator/">CALCULATOR</a>
        <a href="/services/">SERVICES</a>
        <a href="/newsletter/" style="color:var(--yellow); font-weight:700;">SUBSCRIBE</a>
      </nav>
    </div>
    <div class="wrap" style="padding-top:4rem; padding-bottom:4.5rem;">
      <div style="color:var(--yellow); font-size:0.8rem; letter-spacing:0.2em; font-weight:700;">NO. 07 — THE PRIVATE SERVICES ISSUE</div>
      <h1 style="font-size:clamp(3rem,9vw,5.5rem); font-weight:900; line-height:0.98; letter-spacing:-0.04em; margin:1.2rem 0 0;">
        STOP<br />DISPENSING<br /><span style="color:var(--yellow);">PROFIT.</span>
      </h1>
      <p style="color:var(--dim); max-width:400px; font-size:1.05rem; margin:1.5rem 0 2rem;">
        This issue: the nine services that out-earn your dispensary per hour — and the machine that keeps them booked.
      </p>
      <a class="btn" href={`/${lead.data.category}/${lead.id}/`}>Read the cover story</a>
      <div style="display:flex; gap:1.75rem; margin-top:3rem; flex-wrap:wrap;">
        {[
          ['TRAVEL', '£110/visit'],
          ['EAR WAX', '£60/25 min'],
          ['GLP-1', '£199/month'],
          ['AI AGENT', 'answers 24/7'],
        ].map(([k, v]) => (
          <div style="border-top:3px solid var(--yellow); padding-top:0.6rem; min-width:110px;">
            <div style="font-size:0.7rem; letter-spacing:0.15em; color:var(--dim); font-weight:700;">{k}</div>
            <div style="font-weight:700; font-size:1rem;">{v}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <main class="wrap" style="padding-top:3rem;">
    <div style="display:flex; justify-content:space-between; align-items:baseline; border-bottom:3px solid var(--navy); padding-bottom:0.6rem;">
      <h2 style="margin:0; font-size:1.2rem; font-weight:900; letter-spacing:0.06em;">IN THIS ISSUE</h2>
      <a href="/private-services/" style="font-size:0.85rem; font-weight:700; color:#0284c7;">All playbooks →</a>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.75rem; padding:1.75rem 0;">
      {toc.map((a, i) => (
        <a class="toc-item" href={`/${a.data.category}/${a.id}/`} style="display:flex; gap:1rem;">
          <span style="font-weight:900; font-size:2rem; color:var(--yellow); -webkit-text-stroke:1.5px var(--navy); line-height:1;">{i + 2}</span>
          <span>
            <span style="font-size:0.7rem; font-weight:700; letter-spacing:0.1em; color:#0284c7;">{a.data.categoryTitle.toUpperCase()}</span>
            <div class="tt" style="font-weight:700; line-height:1.3; margin-top:0.2rem;">{a.data.title}</div>
          </span>
        </a>
      ))}
      <a class="toc-item" href="/tools/profit-calculator/" style="display:flex; gap:1rem;">
        <span style="font-weight:900; font-size:2rem; color:var(--yellow); -webkit-text-stroke:1.5px var(--navy); line-height:1;">★</span>
        <span>
          <span style="font-size:0.7rem; font-weight:700; letter-spacing:0.1em; color:#0284c7;">FREE TOOL</span>
          <div class="tt" style="font-weight:700; line-height:1.3; margin-top:0.2rem;">The private services profit calculator — your number in 30 seconds</div>
        </span>
      </a>
    </div>
  </main>

  <section style="background:var(--yellow); margin-top:1.5rem;">
    <div class="wrap" style="display:flex; justify-content:space-between; align-items:center; padding-top:2rem; padding-bottom:2rem; flex-wrap:wrap; gap:1rem;">
      <div>
        <div style="font-weight:900; font-size:1.3rem; letter-spacing:-0.02em;">Next issue lands in your inbox.</div>
        <div style="font-size:0.92rem;">One money-making idea a week. Free. No fluff.</div>
      </div>
      <a href="/newsletter/" class="btn" style="background:var(--navy); color:#fff;">Subscribe free</a>
    </div>
  </section>

  <footer class="wrap" style="padding:1.5rem 1.5rem 2.5rem; display:flex; justify-content:space-between; font-size:0.8rem; color:#64748b;">
    <span>© 2026 Pharmacy Business Insights</span>
    <a href="/previews/" style="color:#0284c7; font-weight:600;">← All six concepts</a>
  </footer>
</body>
</html>
