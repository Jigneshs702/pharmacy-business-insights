---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
---
<ServiceLayout
  metaTitle="Google Business Profile Optimisation for Pharmacies"
  metaDescription="Your Google Business Profile decides who walks in and who books. I optimise pharmacy profiles to win local searches for private services, Pharmacy First and more."
  eyebrow="Google Business Profile"
  headline="Win the local searches that happen before every booking"
  subhead="When someone searches 'ear wax removal near me' or 'travel vaccinations [your town]', Google shows three pharmacies. If you're not one of them, that patient is spending their money somewhere else — today."
  problems={[
    'Your profile lists you as just “Pharmacy” while competitors show up for the private services you both offer.',
    'Old photos, wrong hours, unanswered reviews — and Google notices all of it.',
    'You have no idea how many calls or direction requests your profile generates (or loses).',
    'A competitor with worse service outranks you purely because their profile is worked on.',
  ]}
  steps={[
    { title: 'Deep audit', text: 'I benchmark your profile against the pharmacies beating you, across categories, services, photos, reviews, posts and Q&A.' },
    { title: 'Full rebuild', text: 'Every service you offer gets properly listed and described with the search terms patients actually use in your area.' },
    { title: 'Review engine', text: 'A simple in-pharmacy system that turns happy patients into a steady stream of five-star reviews — the single biggest local ranking factor you control.' },
  ]}
  outcomes={[
    'Ranking in the local map pack for your most profitable services',
    'More calls, more direction requests, more walk-ins — measured monthly',
    'A review profile that makes choosing you the obvious decision',
    'A profile that keeps working after the engagement ends',
  ]}
  formSubject="GBP Optimisation enquiry (PBI)"
/>
