---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
---
<ServiceLayout
  metaTitle="AI Agents for UK Pharmacies"
  metaDescription="AI agents that answer patient questions, take bookings and chase follow-ups for UK pharmacies — 24/7, without adding staff."
  eyebrow="AI agents"
  headline="An extra team member who never takes a break — and costs less than one shift a week"
  subhead="While you're dispensing, patients are calling, messaging and searching. An AI agent answers them instantly, books them in, and follows them up — trained on your pharmacy, your services, your prices."
  problems={[
    'The phone rings out during the lunchtime rush and every missed call is a missed booking.',
    'Staff answer the same twenty questions every day: prices, opening hours, “do you do travel jabs?”',
    'Patients due a follow-up, a second jab or a repeat appointment quietly never come back.',
    'You know AI could help but every tool you’ve seen is built for American mega-chains, not a UK community pharmacy.',
  ]}
  steps={[
    { title: 'Train', text: 'I build an agent trained on your services, prices, availability and tone — it answers like your best counter assistant, not a generic chatbot.' },
    { title: 'Connect', text: 'It plugs into your website, WhatsApp and phone line, and writes bookings straight into your diary.' },
    { title: 'Automate', text: 'Follow-ups, reminders, review requests and rebooking prompts run automatically — the revenue you were leaking, recovered.' },
  ]}
  outcomes={[
    'Every enquiry answered in seconds, 24 hours a day',
    'Bookings taken while the whole team is busy dispensing',
    'Automatic follow-up that brings patients back without anyone remembering to chase',
    'A monthly report of conversations, bookings and revenue the agent generated',
  ]}
  formSubject="AI Agents enquiry (PBI)"
/>
