---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
---
<ServiceLayout
  metaTitle="Bookings Booster for UK Pharmacies"
  metaDescription="A done-for-you system that fills your pharmacy's private clinics with bookings: Google visibility, a frictionless booking flow, and automated follow-up."
  eyebrow="Bookings booster"
  headline="Fill your private clinics with paying patients"
  subhead="You've launched the service. The room is ready. The training is done. Now you need patients actually booking — every week, without you chasing them."
  problems={[
    'You offer travel jabs, ear wax removal or weight management — but bookings are a trickle, not a stream.',
    'Patients ring competitors first because they simply appear first on Google.',
    'Enquiries come in, but they don’t turn into booked appointments — no online booking, no reminders, no follow-up.',
    'You’re paying staff for clinic hours that sit empty.',
  ]}
  steps={[
    { title: 'Audit', text: 'I map every step a patient takes from searching on Google to sitting in your consultation room, and show you exactly where you’re losing them.' },
    { title: 'Build', text: 'I fix your Google Business Profile, set up service pages that rank locally, and install a booking flow patients can complete in under a minute.' },
    { title: 'Fill', text: 'Automated reminders, review generation and follow-up sequences keep the diary full and bring patients back season after season.' },
  ]}
  outcomes={[
    'A private clinic diary that fills itself instead of relying on walk-ins',
    'Top-of-Google visibility for the services you actually make money on',
    'Every enquiry captured, reminded and followed up automatically',
    'Clear monthly numbers: searches, calls, bookings, revenue',
  ]}
  formSubject="Bookings Booster enquiry (PBI)"
/>
