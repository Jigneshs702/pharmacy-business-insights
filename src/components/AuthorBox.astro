---
import { AUTHOR } from '../config/site';
---
<div style="display:flex; gap:1.25rem; align-items:flex-start; border:1px solid var(--line); border-radius:12px; padding:1.5rem; margin:2.5rem 0; background:var(--bg-soft);">
  <div style="width:64px; height:64px; border-radius:50%; background:var(--accent-bg); color:var(--accent-dark); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1.3rem; flex-shrink:0;" aria-hidden="true">
    {AUTHOR.name.split(' ').map((w) => w[0]).join('').slice(0, 2)}
  </div>
  <div>
    <strong>{AUTHOR.name}</strong>
    <span class="muted small"> · {AUTHOR.credential}</span>
    <p class="small" style="margin:0.4rem 0 0;">{AUTHOR.bio}</p>
  </div>
</div>
