---
import { CONTACT } from '../config/site';
interface Props {
  subject: string;
  button?: string;
}
const { subject, button = 'Send my enquiry' } = Astro.props;
const enabled = !!CONTACT.web3formsKey;
---
{enabled ? (
  <form action="https://api.web3forms.com/submit" method="POST" style="display:grid; gap:1rem; max-width:520px;">
    <input type="hidden" name="access_key" value={CONTACT.web3formsKey} />
    <input type="hidden" name="subject" value={subject} />
    <input type="hidden" name="from_name" value="Pharmacy Business Insights" />
    <input type="checkbox" name="botcheck" style="display:none;" tabindex="-1" autocomplete="off" />
    <div>
      <label for="name">Your name</label>
      <input id="name" type="text" name="name" required />
    </div>
    <div>
      <label for="pharmacy">Pharmacy name</label>
      <input id="pharmacy" type="text" name="pharmacy" required />
    </div>
    <div>
      <label for="email">Email</label>
      <input id="email" type="email" name="email" required />
    </div>
    <div>
      <label for="phone">Phone (optional)</label>
      <input id="phone" type="tel" name="phone" />
    </div>
    <div>
      <label for="message">What do you want to achieve?</label>
      <textarea id="message" name="message" rows="4"></textarea>
    </div>
    <button type="submit" class="btn">{button}</button>
  </form>
) : (
  <p>
    Email me at <a href={`mailto:${CONTACT.email}?subject=${encodeURIComponent(subject)}`}><strong>{CONTACT.email}</strong></a>{' '}
    with your pharmacy name and what you want to achieve, and I'll reply personally.
  </p>
)}
