---
import { NEWSLETTER, CONTACT } from '../config/site';
const enabled = !!CONTACT.web3formsKey;
---
<div class="cta-box" id="newsletter">
  <h3>{NEWSLETTER.headline}</h3>
  <p>{NEWSLETTER.pitch}</p>
  {enabled ? (
    <form action="https://api.web3forms.com/submit" method="POST" style="display:flex; gap:0.75rem; flex-wrap:wrap;">
      <input type="hidden" name="access_key" value={CONTACT.web3formsKey} />
      <input type="hidden" name="subject" value="New PBI newsletter subscriber" />
      <input type="hidden" name="from_name" value="Pharmacy Business Insights" />
      <input type="checkbox" name="botcheck" style="display:none;" tabindex="-1" autocomplete="off" />
      <input type="email" name="email" required placeholder="you@yourpharmacy.co.uk" aria-label="Email address" style="flex:1; min-width:220px;" />
      <button type="submit" class="btn">Get free ideas</button>
    </form>
  ) : (
    <p style="margin:0;"><a href="/contact/" class="btn">Join the newsletter</a></p>
  )}
</div>
