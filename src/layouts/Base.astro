---
import '../styles/global.css';
import { SITE, AUTHOR, NEWSLETTER } from '../config/site';
import NewsletterBox from '../components/NewsletterBox.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description: string;
  type?: string;
  noNewsletter?: boolean;
  schema?: object | object[];
}

const { title, description, type = 'website', noNewsletter = false, schema } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE.url).href;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.url,
  founder: { '@type': 'Person', name: AUTHOR.name },
};

const schemas = [orgSchema, ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <Sidebar />

    <div class="main-col">
      <main>
        <slot />
      </main>

      {!noNewsletter && (
        <div class="narrow" style="padding-bottom:3.5rem;">
          <NewsletterBox />
        </div>
      )}

      <footer class="section-navy" style="margin-top:0;">
        <div class="container" style="padding-top:3rem; padding-bottom:2.5rem; display:grid; gap:2rem; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); font-size:0.95rem;">
          <div>
            <span style="font-weight:800; font-size:1.15rem; letter-spacing:-0.02em;">
              <span style="color:#7dd3fc;">Pharmacy Business</span> <span style="color:var(--yellow);">Insights</span>
            </span>
            <p style="color:#94a3b8; margin-top:0.6rem;">{SITE.tagline}. Written by {AUTHOR.name}, {AUTHOR.credential}.</p>
          </div>
          <div>
            <strong style="color:#fff;">Learn</strong><br />
            <a href="/private-services/" style="color:#bae6fd;">Private services playbook</a><br />
            <a href="/tools/profit-calculator/" style="color:#bae6fd;">Profit calculator</a><br />
            <a href="/newsletter/" style="color:#bae6fd;">{NEWSLETTER.headline}</a>
          </div>
          <div>
            <strong style="color:#fff;">Work with me</strong><br />
            <a href="/services/bookings-booster/" style="color:#bae6fd;">Bookings booster</a><br />
            <a href="/services/google-business-profile/" style="color:#bae6fd;">Google Business Profile</a><br />
            <a href="/services/pharmacy-websites/" style="color:#bae6fd;">Pharmacy websites</a><br />
            <a href="/services/ai-agents/" style="color:#bae6fd;">AI agents</a>
          </div>
          <div>
            <strong style="color:#fff;">Site</strong><br />
            <a href="/about/" style="color:#bae6fd;">About</a><br />
            <a href="/contact/" style="color:#bae6fd;">Contact</a><br />
            <a href="/editorial-policy/" style="color:#bae6fd;">Editorial policy</a>
          </div>
        </div>
        <div class="container small" style="padding-bottom:1.75rem; color:#64748b;">
          © {new Date().getFullYear()} {SITE.name}. Information on this site is general guidance for pharmacy businesses, not financial, legal or clinical advice.
        </div>
      </footer>
    </div>
  </body>
</html>
