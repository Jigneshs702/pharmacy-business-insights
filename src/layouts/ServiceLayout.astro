---
import Base from './Base.astro';
import LeadForm from '../components/LeadForm.astro';
import AuthorBox from '../components/AuthorBox.astro';
import { SITE } from '../config/site';

interface Props {
  metaTitle: string;
  metaDescription: string;
  eyebrow: string;
  headline: string;
  subhead: string;
  problems: string[];
  steps: { title: string; text: string }[];
  outcomes: string[];
  formSubject: string;
}

const { metaTitle, metaDescription, eyebrow, headline, subhead, problems, steps, outcomes, formSubject } = Astro.props;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: metaTitle,
  description: metaDescription,
  provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  areaServed: 'GB',
};
---

<Base title={`${metaTitle} | ${SITE.name}`} description={metaDescription} schema={serviceSchema} noNewsletter>
  <section class="section section-blue" style="text-align:center;">
    <div class="container" style="max-width:860px;">
      <span class="pill">{eyebrow}</span>
      <h1>{headline}</h1>
      <p style="font-size:1.3rem; color:var(--muted); max-width:680px; margin:0 auto 2rem;">{subhead}</p>
      <a href="#enquire" class="btn" style="font-size:1.1rem;">Get started — free chat, no pressure</a>
    </div>
  </section>

  <section class="narrow" style="padding-top:1rem;">
    <h2>Sound familiar?</h2>
    <ul>
      {problems.map((p) => <li style="margin-bottom:0.5rem;">{p}</li>)}
    </ul>

    <h2>How it works</h2>
    <div style="display:grid; gap:1.25rem; margin:1.5rem 0 1rem;">
      {steps.map((s, i) => (
        <div style="display:flex; gap:1.25rem; align-items:flex-start; border:1px solid var(--blue-100); border-radius:20px; padding:1.5rem; background:#fff; box-shadow:0 4px 14px -6px rgba(2,6,23,0.08);">
          <span style="font-size:2rem; font-weight:800; color:var(--blue); letter-spacing:-0.03em; line-height:1; flex-shrink:0;">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <strong style="color:var(--navy); font-size:1.1rem;">{s.title}</strong>
            <p style="margin:0.35rem 0 0; color:var(--muted);">{s.text}</p>
          </div>
        </div>
      ))}
    </div>

    <h2>What you get</h2>
    <ul>
      {outcomes.map((o) => <li style="margin-bottom:0.5rem;">{o}</li>)}
    </ul>

    <slot />

    <div class="cta-box" id="enquire">
      <h3>Tell me about your pharmacy</h3>
      <p>I'll reply personally with an honest view of whether this will work for you — and if it won't, I'll say so.</p>
      <LeadForm subject={formSubject} />
    </div>

    <AuthorBox />
  </section>
</Base>
